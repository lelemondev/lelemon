{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["src/**/*", "mcify.config.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
