{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm run:*)",
      "Bash(go run:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(docker-compose:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "WebFetch(domain:lelemon.dev)",
      "WebFetch(domain:api.lelemon.dev)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(apps/web/.env)",
      "Read(apps/web/.env.*)",
      "Read(apps/server/.env)",
      "Read(apps/server/.env.*)",
      "Read(ee/server/.env)",
      "Read(ee/server/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.secret)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
